{
  "prefix_mode": {
    "description": "前缀模式",
    "hint": "开启后，仅在消息满足前缀或唤醒条件时触发 API。",
    "type": "bool",
    "default": false
  },
  "enable_fuzzy_match": {
    "description": "全局模糊匹配",
    "hint": "启用时表示关键词“包含匹配”，未启用表示关键词“精准匹配”。若单个 API 配置了此选项，则该 API 配置优先于此全局开关。",
    "type": "bool",
    "default": false
  },
  "auto_save_data": {
    "description": "保存 API 响应数据",
    "hint": "建议开启。接口异常时可使用本地已保存数据进行兜底；若存储空间紧张可关闭。",
    "type": "bool",
    "default": true
  },
  "type_switch": {
    "description": "类型开关",
    "type": "object",
    "items": {
      "enable_text": {
        "description": "启用文本 API",
        "type": "bool",
        "default": true
      },
      "enable_image": {
        "description": "启用图片 API",
        "type": "bool",
        "default": true
      },
      "enable_video": {
        "description": "启用视频 API",
        "type": "bool",
        "default": true
      },
      "enable_audio": {
        "description": "启用音频 API",
        "type": "bool",
        "default": true
      }
    }
  },
  "api_keys": {
    "description": "API 密钥",
    "hint": "部分站点需要密钥访问。格式：https://your.api.com:your_api_key（站点域名:密钥）。",
    "type": "list",
    "default": [
      "http://api.317ak.cn:api_key"
    ]
  },
  "error_reply": {
    "description": "接口异常回复内容",
    "hint": "当接口返回异常且本项非空时，直接回复该内容；留空则使用本地兜底逻辑。",
    "type": "string",
    "default": ""
  },
  "disable_sites": {
    "description": "禁用站点列表",
    "hint": "可填站点前缀或站点根地址。",
    "type": "list",
    "default": [
      "https://your.api.com"
    ]
  },
  "disable_apis": {
    "description": "禁用 API 列表",
    "hint": "列表项可填写 API 名称或关键词。命中后该 API 不会被本插件处理。",
    "type": "list",
    "default": []
  }
}
